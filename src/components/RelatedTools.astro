---
export interface Props {
  tools: Array<{ href: string; name: string; desc: string }>;
}
const { tools } = Astro.props;
---

<section style="margin-top:36px;">
  <h2 style="font-size:1.25rem; margin:0 0 12px;">関連ツール</h2>
  <div class="grid">
    {tools.map((t) => (
      <a class="card" href={t.href}>
        <h3>{t.name}</h3>
        <p>{t.desc}</p>
      </a>
    ))}
  </div>
  <p style="margin-top:10px; font-size:.9rem;">
    <a href="/">← すべての計算ツール一覧</a>
  </p>
</section>
