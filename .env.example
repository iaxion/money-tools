# 環境変数のテンプレート。実際の値は .env（ローカル）や
# Cloudflare Pages の「環境変数」/ GitHub Secrets に設定してください。
# このファイル自体に本物の値や個人情報を書かないこと。

# 公開URL（独自ドメイン・末尾スラッシュ不要）
PUBLIC_SITE_URL=https://example.com

# 問い合わせ先メールアドレス
PUBLIC_CONTACT_EMAIL=you@example.com

# Google AdSense パブリッシャーID（審査通過後に設定。例 ca-pub-XXXXXXXXXXXXXXXX）
PUBLIC_ADSENSE_CLIENT=

# 任意: サイト名・運営者名（未設定なら既定値を使用）
# PUBLIC_SITE_NAME=お金の計算ツール
# PUBLIC_SITE_AUTHOR=運営者
